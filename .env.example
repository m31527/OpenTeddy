# ─── OpenTeddy Environment Configuration ───────────────────────────────────
# Copy this file to .env and fill in your values.

# ── Anthropic (required for Claude escalation & Skill Factory) ───────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Claude model for escalation / skill generation ───────────────────────────
CLAUDE_MODEL=claude-opus-4-6

# ── Gemma Orchestrator (Ollama) ───────────────────────────────────────────────
GEMMA_BASE_URL=http://localhost:11434
GEMMA_MODEL=gemma3:4b

# ── Qwen Executor (Ollama) ────────────────────────────────────────────────────
QWEN_BASE_URL=http://localhost:11434
QWEN_MODEL=qwen2.5:3b

# ── Database ──────────────────────────────────────────────────────────────────
DB_PATH=openteddy.db

# ── Skills directory ──────────────────────────────────────────────────────────
SKILLS_DIR=skills

# ── Escalation ────────────────────────────────────────────────────────────────
ESCALATION_THRESHOLD=0.6
ESCALATION_FAILURE_LIMIT=3

# ── API server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Skill growth ──────────────────────────────────────────────────────────────
SKILL_PROMOTION_THRESHOLD=5
MAX_SKILL_TOKENS=2048
