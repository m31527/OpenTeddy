# ─── OpenTeddy Environment Configuration ───────────────────────────────────
# Copy this file to .env and fill in your values.

# ── Anthropic (required for Claude escalation & Skill Factory) ───────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Claude model for escalation / skill generation ───────────────────────────
CLAUDE_MODEL=claude-opus-4-6

# ── Gemma Orchestrator (Ollama) ───────────────────────────────────────────────
GEMMA_BASE_URL=http://localhost:11434
GEMMA_MODEL=gemma3:4b

# ── Qwen Executor (Ollama) ────────────────────────────────────────────────────
QWEN_BASE_URL=http://localhost:11434
QWEN_MODEL=qwen2.5:3b

# ── SQLite tracker database ───────────────────────────────────────────────────
DB_PATH=openteddy.db

# ── Long-term Memory (ChromaDB local vector DB) ───────────────────────────────
# ChromaDB stores embeddings here — no external service required.
MEMORY_DB_PATH=./memory_db

# ── Skills directory ──────────────────────────────────────────────────────────
SKILLS_DIR=skills

# ── Escalation ────────────────────────────────────────────────────────────────
ESCALATION_THRESHOLD=0.6
ESCALATION_FAILURE_LIMIT=3

# ── API server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Skill growth ──────────────────────────────────────────────────────────────
SKILL_PROMOTION_THRESHOLD=5
MAX_SKILL_TOKENS=2048

# ═══════════════════════════════════════════════════════════════════════════════
# Tool System (新增)
# ═══════════════════════════════════════════════════════════════════════════════

# ── External DB tool (SQLAlchemy async URL) ───────────────────────────────────
# Postgres:  postgresql+asyncpg://user:password@host:5432/dbname
# MySQL:     mysql+aiomysql://user:password@host:3306/dbname
# SQLite:    sqlite+aiosqlite:///./mydb.sqlite3
DATABASE_URL=postgresql+asyncpg://user:pass@localhost/mydb

# ── GCP credentials ───────────────────────────────────────────────────────────
# Path to your Google service account JSON key file.
# Required for: gcp_storage_*, gcp_bigquery_*, gcp_pubsub_publish
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── Python venv for pip_install (isolated from system Python) ─────────────────
# The pip_install tool will install packages here instead of the system Python.
# Create with: python -m venv /Users/sean/other_projects/OpenTeddy/.venv
VENV_PATH=/Users/sean/other_projects/OpenTeddy/.venv
