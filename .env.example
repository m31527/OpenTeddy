# ─── OpenTeddy Environment Configuration ───────────────────────────────────
# Copy this file to .env and fill in your values.
#
# Note: most of these settings are also exposed in the web UI (Settings tab)
# and persisted to the SQLite settings store. .env only provides first-run
# defaults for a fresh install — once the app starts, the DB becomes the
# source of truth. Changes here require a clean DB to take effect.


# ═══════════════════════════════════════════════════════════════════════════════
# Core: Model endpoints
# ═══════════════════════════════════════════════════════════════════════════════

# ── Anthropic (required for Claude escalation & Skill Factory) ───────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Claude model for escalation / skill generation ───────────────────────────
CLAUDE_MODEL=claude-opus-4-6

# ── Gemma Orchestrator (Ollama) ──────────────────────────────────────────────
GEMMA_BASE_URL=http://localhost:11434
GEMMA_MODEL=gemma3:4b
GEMMA_MAX_TOKENS=4096

# ── Qwen Executor (Ollama) ───────────────────────────────────────────────────
QWEN_BASE_URL=http://localhost:11434
QWEN_MODEL=qwen2.5:3b
QWEN_MAX_TOKENS=4096


# ═══════════════════════════════════════════════════════════════════════════════
# Storage paths
# ═══════════════════════════════════════════════════════════════════════════════

# ── SQLite tracker database ──────────────────────────────────────────────────
DB_PATH=openteddy.db

# ── Long-term Memory (ChromaDB local vector DB) ──────────────────────────────
# ChromaDB stores embeddings here — no external service required.
MEMORY_DB_PATH=./memory_db

# ── Skills directory ─────────────────────────────────────────────────────────
SKILLS_DIR=skills

# ── Agent workspace (Code / Analytic 模式預設 working directory) ─────────────
# 所有 shell 指令如果沒有指定 working_dir，都會預設在這裡執行。
# 不存在時會在啟動時自動建立。
AGENT_WORKSPACE_DIR=./agent-workspace


# ═══════════════════════════════════════════════════════════════════════════════
# Escalation & self-growth thresholds
# ═══════════════════════════════════════════════════════════════════════════════

# Escalate to Claude when local executor confidence is below this value
ESCALATION_THRESHOLD=0.6

# Consecutive local failures before escalating
ESCALATION_FAILURE_LIMIT=3

# Wall-clock hard stop for a subtask (seconds). The real safety net is
# SHELL_SILENCE_TIMEOUT below — this just caps truly-runaway subtasks.
# 900s = 15 min is enough for a legitimate docker compose up --build on
# a fresh repo with multiple image pulls.
SUBTASK_TIMEOUT=900

# Kill a shell command after this many seconds of zero output.
# Long-but-active commands (docker build, pip install) stay alive as long
# as they print progress; truly hung commands (DNS stuck, interactive
# prompt, deadlock) get caught within this window. Set 0 to disable
# and fall back to the wall-clock subtask timeout only.
SHELL_SILENCE_TIMEOUT=90

# Minimum similarity score to reuse an existing skill (0.0–1.0)
SKILL_MATCH_THRESHOLD=0.4

# Successful runs required before a skill is promoted to ACTIVE
SKILL_PROMOTION_THRESHOLD=5

# Maximum tokens for skill-code generation
MAX_SKILL_TOKENS=2048


# ═══════════════════════════════════════════════════════════════════════════════
# API server
# ═══════════════════════════════════════════════════════════════════════════════

API_HOST=0.0.0.0
API_PORT=8000


# ═══════════════════════════════════════════════════════════════════════════════
# Tool integrations (optional — only set the ones you actually use)
# ═══════════════════════════════════════════════════════════════════════════════

# ── External DB tool (SQLAlchemy async URL) ──────────────────────────────────
# Postgres:  postgresql+asyncpg://user:password@host:5432/dbname
# MySQL:     mysql+aiomysql://user:password@host:3306/dbname
# SQLite:    sqlite+aiosqlite:///./mydb.sqlite3
DATABASE_URL=postgresql+asyncpg://user:pass@localhost/mydb

# ── GitHub ───────────────────────────────────────────────────────────────────
GITHUB_TOKEN=gho_your_token_here

# ── GCP credentials ──────────────────────────────────────────────────────────
# Path to your Google service account JSON key file.
# Required for: gcp_storage_*, gcp_bigquery_*, gcp_pubsub_publish
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── Python venv for pip_install (isolated from system Python) ────────────────
# The pip_install tool installs packages here instead of the system Python.
# Create with: python -m venv ./.venv
VENV_PATH=./.venv
