# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg
.eggs/

# Virtual environments
venv/
.venv/
env/
.env

# Database
*.db
*.sqlite
*.sqlite3

# Skills (generated at runtime — keep the .gitkeep)
skills/*.py
# Helper modules that *aren't* auto-generated skills DO belong in git —
# whitelist them back so the gitignore rule above only catches the
# Claude-generated runtime skill files.
!skills/_premium.py
!skills/__init__.py

# Logs
*.log
logs/

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# Test / coverage
.coverage
htmlcov/
.pytest_cache/

# Landing page (separate repo)
landing-page/

# Desktop client (separate repo, not part of this repo)
desktop/

# Agent workspace — runtime scratch dir for git clones, file writes,
# uploaded user data. Not part of the source tree.
agent-workspace/
