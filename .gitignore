# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg
.eggs/

# Virtual environments
venv/
.venv/
env/
.env

# Database
*.db
*.sqlite
*.sqlite3

# Skills (generated at runtime — keep the .gitkeep)
skills/*.py
# Helper modules that *aren't* auto-generated skills DO belong in git —
# whitelist them back so the gitignore rule above only catches the
# Claude-generated runtime skill files.
!skills/_premium.py
!skills/__init__.py

# Logs
*.log
logs/

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# Test / coverage
.coverage
htmlcov/
.pytest_cache/

# Landing page (separate repo)
landing-page/

# Desktop client (separate repo, not part of this repo)
desktop/

# Agent workspace — runtime scratch dir for git clones, file writes,
# uploaded user data. Not part of the source tree.
agent-workspace/

# Claude Code local-only state. settings.local.json is the per-machine
# allowlist of permitted bash/tool calls (different on every developer
# machine); worktrees/ holds Claude's temporary isolated checkouts. Both
# get accidentally committed if a contributor runs `git add .` without
# thinking — and once tracked they create perpetual dirty-tree noise
# that even blocks release.sh's pre-flight clean check. Keep the rest
# of .claude/ (memory, commands, etc.) tracked when projects choose to
# share them — only these two paths are auto-generated local cruft.
.claude/settings.local.json
.claude/worktrees/

# ChromaDB local vector store — recreated at runtime from tasks.
memory_db/

# Cyber-skills index — committed to the repo so new installs work out
# of the box (no GitHub API token needed on first launch). Rebuild it
# before each release with `python cyber_skills/update.py`; the bumped
# version goes in with the same commit as the version bump. We tried
# the "rebuild on first launch" approach earlier — it failed on macOS
# desktop builds (PyInstaller bundles can't subprocess update.py) and
# on servers with no `gh` auth (GitHub API 401 + 60/hr rate limit).
