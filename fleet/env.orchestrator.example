# ═══════════════════════════════════════════════════════════════════════════════
# OpenTeddy Fleet — CENTRAL (orchestrator) node .env
# ═══════════════════════════════════════════════════════════════════════════════
#
# Copy this to the central node's .env (append to its existing .env, or
# merge these keys in). EXACTLY ONE node in the fleet runs as orchestrator.
#
#   cp fleet/env.orchestrator.example .env       # fresh install, OR
#   cat fleet/env.orchestrator.example >> .env   # append to existing
#
# Then restart OpenTeddy. Confirm with:
#   curl -s http://localhost:8000/fleet/nodes | python3 -m json.tool
# ─────────────────────────────────────────────────────────────────────────────

# Shared secret — MUST be identical on the central + every worker. It's the
# token nodes use to trust each other. Generate once with:
#     openssl rand -hex 32
# then paste the SAME value into every node's .env.
OPENTEDDY_FLEET_TOKEN=paste-the-same-long-random-secret-on-every-node

# Role for THIS node. The central is the single "orchestrator".
OPENTEDDY_FLEET_ROLE=orchestrator

# WebSocket port workers dial into. Binds 0.0.0.0 so LAN workers can reach
# it — keep the fleet behind a firewall / private mesh (WireGuard / Tailscale).
OPENTEDDY_FLEET_PORT=8770

# (optional) How long without a heartbeat before a node is marked offline.
# Workers heartbeat every 15s; 45s = 3 missed beats.
# OPENTEDDY_FLEET_HEARTBEAT_TIMEOUT=45
